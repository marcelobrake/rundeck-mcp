# =============================================================================
# Rundeck MCP Server — Configuração via variáveis de ambiente
# Copie para .env e preencha os valores. NUNCA comite o .env no git.
# =============================================================================

# -----------------------------------------------------------------------------
# OBRIGATÓRIOS
# -----------------------------------------------------------------------------
RUNDECK_URL=http://rundeck.sua-empresa.com:4440
RUNDECK_TOKEN=seu_api_token_aqui

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
RUNDECK_API_VERSION=57

# -----------------------------------------------------------------------------
# TLS / SSL
# Produção: mantenha VERIFY_SSL=true
# Se usar CA interna, aponte CA_BUNDLE para o arquivo .pem
# -----------------------------------------------------------------------------
RUNDECK_VERIFY_SSL=true
# RUNDECK_CA_BUNDLE=/etc/ssl/certs/ca-bundle.pem

# -----------------------------------------------------------------------------
# HTTP CLIENT — Timeouts (segundos)
# Aumente TIMEOUT_READ para jobs lentos com output grande
# -----------------------------------------------------------------------------
RUNDECK_TIMEOUT_CONNECT=5.0
RUNDECK_TIMEOUT_READ=30.0
RUNDECK_TIMEOUT_WRITE=10.0
RUNDECK_MAX_CONNECTIONS=20
RUNDECK_MAX_KEEPALIVE_CONNECTIONS=10
RUNDECK_KEEPALIVE_EXPIRY=30.0

# -----------------------------------------------------------------------------
# RETRY — Backoff exponencial
# Tentativas: 1, 2, 4, 8... segundos de espera
# -----------------------------------------------------------------------------
RUNDECK_RETRY_ATTEMPTS=3
RUNDECK_RETRY_WAIT_SECONDS=1.0

# -----------------------------------------------------------------------------
# CACHE — TTL em segundos (0 = desativado)
# Rotas de leitura (list_jobs, list_projects, etc) são cacheadas
# -----------------------------------------------------------------------------
RUNDECK_CACHE_TTL_SECONDS=30

# -----------------------------------------------------------------------------
# SEGURANÇA
# EXECUTION_ENABLED=false = modo somente leitura (recomendado para ambientes sensíveis)
# ALLOWED_PROJECTS = lista separada por vírgula; vazio = todos os projetos liberados
# -----------------------------------------------------------------------------
RUNDECK_EXECUTION_ENABLED=true
# RUNDECK_ALLOWED_PROJECTS=projeto-dev,projeto-hml

# -----------------------------------------------------------------------------
# OUTPUT / LOGS
# LOG_OUTPUT_MAX_LINES: limite de linhas de log retornadas por execução
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
# -----------------------------------------------------------------------------
RUNDECK_LOG_OUTPUT_MAX_LINES=500
RUNDECK_LOG_DIR=logs
RUNDECK_LOG_LEVEL=INFO
RUNDECK_VPN_NAME=My VPN Name
RUNDECK_VPN_AUTO_CONNECT=false

# -----------------------------------------------------------------------------
# OBSERVABILIDADE
# OTLP é opt-in: sem OTEL_EXPORTER_OTLP_ENDPOINT nada é exportado para fora.
# Exemplo: http://tempo.monitoring.svc.cluster.local:4317
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# -----------------------------------------------------------------------------
# TRANSPORT MCP
# stdio: Claude Desktop (padrão)
# sse:   servidor HTTP para integração remota
# -----------------------------------------------------------------------------
RUNDECK_TRANSPORT=stdio
